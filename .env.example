# Database (Render PostgreSQL)
DATABASE_URL=jdbc:postgresql://[host]:[port]/[database]
DATABASE_USERNAME=tu_usuario
DATABASE_PASSWORD=tu_password

# JWT (genera una clave segura)
JWT_SECRET=tu_clave_jwt_muy_larga_y_segura
JWT_EXPIRATION_MS=86400000

# Groq AI (producción)
# Obtén tu API key en: https://console.groq.com/keys
GROQ_API_KEY=tu_api_key_de_groq
GROQ_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_CONNECT_TIMEOUT_MS=10000
GROQ_READ_TIMEOUT_MS=60000
GROQ_MAX_TOKENS=520

# Ollama (desarrollo local, opcional)
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=phi3:mini

# CORS (separados por coma)
# Desarrollo: http://localhost:4321,http://localhost:3000
# Producción: https://tu-dominio.onrender.com
CORS_ORIGINS=http://localhost:4321,http://localhost:3000
